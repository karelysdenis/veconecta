generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  role        Role      @default(EDITOR)
  countrySlugs String[] @default([])
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  sessions    Session[]
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MagicToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Country {
  slug          String     @id
  nameEs        String
  nameEn        String
  namePt        String?
  nameFr        String?
  nameDe        String?
  flag          String
  cca2          String?
  active        Boolean    @default(true)
  lastUpdatedAt DateTime   @updatedAt
  resources     Resource[]
  cities        City[]
}

model City {
  id          String     @id @default(cuid())
  countrySlug String
  country     Country    @relation(fields: [countrySlug], references: [slug])
  slug        String
  nameEs      String
  nameEn      String?
  namePt      String?
  nameFr      String?
  nameDe      String?
  resources   Resource[]

  @@unique([countrySlug, slug])
  @@index([countrySlug])
}

model Resource {
  id          String           @id @default(cuid())
  countrySlug String
  country     Country          @relation(fields: [countrySlug], references: [slug])
  category    ResourceCategory
  name        String
  nameEn      String?
  namePt      String?
  nameFr      String?
  nameDe      String?
  cityId      String?
  city        City?            @relation(fields: [cityId], references: [id])
  url         String?
  phone       String?
  bizum       String?
  address     String?
  schedule    String?
  free        Boolean          @default(false)
  notesEs     String?
  notesEn     String?
  notesPt     String?
  notesFr     String?
  notesDe     String?
  status      ResourceStatus   @default(DRAFT)
  verifiedAt  DateTime?
  verifiedBy  String?
  expiresAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status])
  @@index([countrySlug])
  @@index([cityId])
}

model AuditLog {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  userEmail   String
  action      String
  entityType  String
  entityId    String?
  entityName  String?
  countrySlug String?
  detail      String?

  @@index([createdAt(sort: Desc)])
  @@index([countrySlug])
  @@index([userEmail])
}

model CommunityReport {
  id          String   @id @default(cuid())
  resourceId  String?
  countrySlug String
  message     String
  url         String?
  resolved    Boolean  @default(false)
  ipHash      String?
  createdAt   DateTime @default(now())

  @@index([resolved, countrySlug])
  @@index([ipHash, createdAt])
}

enum Role {
  ADMIN
  EDITOR
}

enum ResourceCategory {
  FIND_FAMILY
  DONATE_MONEY
  SEND_MONEY
  CALL_FREE
  DONATE_PHYSICALLY
  DIGITAL_BRIDGE
  CONSULAR
  MENTAL_HEALTH
}

enum ResourceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}
